{
  "name": "homebridge-tibber-price-next",
  "displayName": "Homebridge Tibber Price Next",
  "version": "0.1.0",
  "description": "Neuaufbau eines Homebridge-Plugins fuer Tibber-Preise mit flexiblen Zeitslots",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20",
    "homebridge": ">=1.8.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "prepare": "npm run clean && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "tibber",
    "energy",
    "dynamic-pricing"
  ],
  "dependencies": {
    "homebridge": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "eslint": "^9.25.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}

